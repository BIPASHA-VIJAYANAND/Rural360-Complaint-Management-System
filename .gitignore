# Root .gitignore for Panchayat System DOSC

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc data
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (http://bower.io/)
bower_components

# node-waf configuration
node_modules
jspm_packages

# TypeScript v1-v2 build artifacts
typings

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Workspace-specific files
.yarn-integrity

# dotenv environment variables files
.env
.env.test
.env.local
.env.development.local
.env.test.local
.env.production.local

# flask venv
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class

# Oracle Instant Client
instantclient*/

# Vite/React build
dist/
dist-ssr/
*.local

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Project specific
backend/venv/
backend/__pycache__/
backend/.env
frontend/node_modules/
frontend/dist/
PanchayatMobile/node_modules/
PanchayatMobile/.expo/
PanchayatMobile/dist/
